modules = ["nodejs-20", "web", "bash", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Question Bank"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && PORT=8080 DATABASE_URL=$NEON_DATABASE_URL pnpm run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Question Bank"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/question-bank && PORT=8081 BASE_PATH=/question-bank pnpm run dev"
waitForPort = 8081

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 8084
externalPort = 4200

[[ports]]
localPort = 8085
externalPort = 3002

[[ports]]
localPort = 8086
externalPort = 5173

[[ports]]
localPort = 8087
externalPort = 5000

[[ports]]
localPort = 8088
externalPort = 6000

[[ports]]
localPort = 8089
externalPort = 6800

[[ports]]
localPort = 8090
externalPort = 8000

[[ports]]
localPort = 8091
externalPort = 8008

[[ports]]
localPort = 8092
externalPort = 8081

[[ports]]
localPort = 8093
externalPort = 8099

[[ports]]
localPort = 8094
externalPort = 9000

[[ports]]
localPort = 24503
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
